datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id      String   @id @default(uuid())
  name    String
  apiKey  String   @unique
  users   User[]
  logs    ZakatLog[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  logs      ZakatLog[]
}

model ZakatLog {
  id         String   @id @default(uuid())
  assetType  String   
  amount     Float
  calculated Float    
  userId     String
  tenantId   String
  user       User     @relation(fields: [userId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  createdAt  DateTime @default(now())
}